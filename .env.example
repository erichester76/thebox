# ─────────────────────────────────────────────────────────────────────────────
# TheBox — Environment Configuration
# Copy this file to .env and adjust the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# Timezone
TZ=America/New_York

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=thebox
POSTGRES_USER=thebox
POSTGRES_PASSWORD=change_me_in_production

# ─── Pi-hole ─────────────────────────────────────────────────────────────────
# Pi-hole v6 API base URL — must be reachable from within the Docker network.
# Typically http://pihole:80 when using the bundled Pi-hole container.
PIHOLE_URL=http://pihole:80
PIHOLE_PASSWORD=change_me_in_production
PIHOLE_DNS_PORT=53
PIHOLE_WEB_PORT=8080

# ─── Dashboard ───────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
SECRET_KEY=change_me_in_production_to_a_random_string
# Seconds a Pi-hole v6 session ID is cached before re-authenticating.
# Pi-hole sessions last 300 s by default; set this lower if you see 401 errors.
PIHOLE_SID_TTL=240

# ─── Network Discovery ───────────────────────────────────────────────────────
# Comma-separated list of CIDR ranges to scan
NETWORK_RANGES=192.168.1.0/24
# Scan interval in seconds (default: 5 minutes)
SCAN_INTERVAL=300
# Enable DNS packet sniffing to discover devices from their DNS queries
# (requires NET_RAW capability; most effective with network_mode: host on Linux)
DNS_SNIFF_ENABLED=true
# Network interface to sniff on (leave empty for auto-detection)
DNS_SNIFF_IFACE=
# Enable SSDP/UPnP multicast discovery (finds routers, smart TVs, NAS, etc.)
SSDP_ENABLED=true
# Seconds to wait for SSDP responses per scan cycle
SSDP_TIMEOUT=5
# Enable mDNS/Zeroconf (Bonjour/Avahi) service browser
# (finds Apple, Chromecast, printers, HomeKit, and other Zeroconf-capable devices)
MDNS_ENABLED=true
# Enable NetBIOS/NBNS subnet scan via nmap nbstat script (finds Windows/Samba hosts)
NETBIOS_ENABLED=true
# Enable HTTP/HTTPS banner grabbing to extract server software and TLS cert info
BANNER_GRAB_ENABLED=true
# Timeout in seconds for HTTP/HTTPS banner connections
BANNER_GRAB_TIMEOUT=3
# Enable DHCP packet sniffing to extract device hostnames from DHCP option 12
# in real time (more reliable than reverse DNS; requires NET_RAW capability)
DHCP_SNIFF_ENABLED=true
# Enable ARP packet sniffing for real-time device detection between scan cycles
# (detects devices the moment they join the network; requires NET_RAW capability)
ARP_SNIFF_ENABLED=true
# How often (seconds) to drain sniff queues and run SSDP/mDNS discovery
# outside of the full scan cycle. Lower values mean faster detection.
SNIFF_PROCESS_INTERVAL=30
# URL for the IEEE MA-L OUI CSV (vendor database); overridable for air-gapped deployments
# OUI_CSV_URL=https://standards-oui.ieee.org/oui/oui.csv
# Local path where the OUI CSV is cached for offline fallback
# OUI_CSV_PATH=/tmp/oui.csv

# ─── DHCP Fingerprint Classification (fingerbank.org) ────────────────────────
# Enable device classification via the fingerbank.org /combinations/interrogate
# API. Sends all available network signals (DHCP option-55 fingerprint, MAC
# address, hostname, DHCP vendor class, mDNS service types, UPnP server
# strings) for the most accurate identification. Unauthenticated requests
# work but are limited to ~100/day.
FINGERBANK_ENABLED=true
# Optional fingerbank.org API key (register free at https://fingerbank.org/users/register)
# FINGERBANK_API_KEY=

# ─── Device Guardian ─────────────────────────────────────────────────────────
# CIDR range used for quarantined devices
QUARANTINE_VLAN=192.168.99.0/24
# Comma-separated list of trusted network ranges
TRUSTED_NETWORKS=192.168.1.0/24
# Automatically quarantine new/unknown devices
AUTO_QUARANTINE=true

# ─── IoT Learning ────────────────────────────────────────────────────────────
# Hours a new IoT device spends in the observation (learning) group before
# its DNS queries are collected and it is moved to the permanent iot group.
IOT_LEARNING_HOURS=48
# Name of the Pi-hole group that IoT devices are placed in after learning.
# This group should be configured in Pi-hole with the IoT allow-list blocklist.
PIHOLE_IOT_GROUP=iot
# Internal URL the discovery service uses to tell Pi-hole where to fetch the
# IoT allow-list feed.  Should point at the dashboard container over the
# thebox_internal Docker network.  Pi-hole will register this as an adlist.
DASHBOARD_URL=http://dashboard:3000

# ─── Honeypot ────────────────────────────────────────────────────────────────
# Comma-separated list of ports the honeypot listens on.
# On macOS, port 22 is automatically excluded by setup.sh because macOS's
# built-in OpenSSH service already binds that port.
HONEYPOT_PORTS=21,22,23,25,53,80,110,135,143,389,443,445,1433,3306,3389,5432,5900,5985,6379,8080,8443,9200,11211,27017
# Comma-separated list of IP addresses or CIDR ranges to silently ignore.
# Connections from these addresses are dropped without logging or alerting.
# The default covers Docker bridge gateway addresses (172.16.0.0/12) and
# loopback (127.0.0.0/8) to prevent internal Docker health-checks from
# flooding the event log.
HONEYPOT_IGNORED_NETWORKS=172.16.0.0/12,127.0.0.0/8

# ── Honeypot severity thresholds ─────────────────────────────────────────────
# Number of hits from a single IP within HONEYPOT_THRESHOLD_WINDOW seconds
# before the severity is escalated (>= count → high, >= 3× count → critical).
HONEYPOT_THRESHOLD_COUNT=3
# Rolling window in seconds for the hit-count threshold above.
HONEYPOT_THRESHOLD_WINDOW=60

# ── Port-sweep detection ──────────────────────────────────────────────────────
# Number of distinct destination ports a single IP must probe within
# HONEYPOT_SWEEP_WINDOW seconds to be classified as a port sweep.
HONEYPOT_SWEEP_THRESHOLD=4
# Rolling window in seconds for sweep detection.
HONEYPOT_SWEEP_WINDOW=60

# ── Protocol interaction ──────────────────────────────────────────────────────
# Seconds the honeypot waits for the attacker to send data after the banner.
HONEYPOT_RECV_TIMEOUT=4
# Maximum number of characters stored as payload_preview in the database.
# Increase if you want to capture longer attacker conversations.
HONEYPOT_MAX_PAYLOAD_LENGTH=2000
# Credential attempts are tracked over a longer window to catch slow brute-force.
# Effective TTL = HONEYPOT_THRESHOLD_WINDOW × this multiplier (seconds).
HONEYPOT_CREDENTIAL_WINDOW_MULTIPLIER=5

# ─── Redirector ──────────────────────────────────────────────────────────────
# Comma-separated list of active redirect modes.
# From least to most intrusive:
#   passive         — monitor only, no active redirection (default)
#   redirect_dns    — iptables DNAT to forward all DNS traffic to Pi-hole
#   arp_spoof       — ARP-spoof LAN hosts to intercept DNS/DHCP traffic
#   dhcp_advertise  — respond to DHCP requests with Pi-hole as DNS server
#   dhcp_starvation — exhaust upstream DHCP pool (WARNING: disruptive)
#   gateway_takeover — full MitM via ARP spoofing all hosts + the gateway
REDIRECT_MODE=passive
# Network interface used for ARP/packet operations (auto-detected on Linux)
NETWORK_INTERFACE=eth0
# Default gateway IP (auto-detected from routing table if left empty)
GATEWAY_IP=
# Pi-hole IP address (defaults to BOX_IP / TheBox's own address if empty)
PIHOLE_IP=
# TheBox's own IP address (auto-detected from NETWORK_INTERFACE if empty)
BOX_IP=
# Drop all traffic from quarantined devices except DHCP and DNS
BLACKHOLE_QUARANTINED=false
# Seconds between ARP refresh packets for active spoof modes
ARP_REFRESH_INTERVAL=10

# ─── Captive portal ───────────────────────────────────────────────────────────
# Serve a quarantine explanation page to blocked HTTP (port 80) clients.
# Requires CAPTIVE_PORTAL_ENABLED=true (default). Disable to turn off the
# portal entirely without changing any other quarantine behaviour.
CAPTIVE_PORTAL_ENABLED=true
# Local port the captive portal HTTP server listens on.
# An iptables PREROUTING REDIRECT rule steers quarantined-device port-80
# traffic here; this port does not need to be reachable from the LAN directly.
CAPTIVE_PORTAL_PORT=8082
# Message displayed on the quarantine page.
CAPTIVE_PORTAL_MESSAGE=Your device has been quarantined because it was not recognized on this network.
# Contact address or URL shown on the quarantine page (leave empty to hide).
CAPTIVE_PORTAL_CONTACT=

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log verbosity level.
#   DEBUG    — detailed diagnostic messages, including per-packet and DB queries
#   INFO     — general operational messages (default)
#   WARNING  — unexpected but non-fatal conditions
#   ERROR    — failures that require immediate attention
#   CRITICAL — severe failures, service may be unusable
LOG_LEVEL=INFO

# ─── Alert Notifications ─────────────────────────────────────────────────────
# Email recipient for alert notifications.  Leave empty to disable email.
ALERT_EMAIL=
# SMTP server hostname.  Required when ALERT_EMAIL is set.
SMTP_HOST=
# SMTP server port (default: 587).
SMTP_PORT=587
# From address used in outbound alert emails.
SMTP_FROM=alerts@thebox.local
# SMTP credentials — leave empty if the server accepts unauthenticated relaying.
SMTP_USER=
SMTP_PASSWORD=
# Set to "false" to disable STARTTLS (not recommended for public SMTP servers).
SMTP_TLS=true
# HTTP(S) endpoint to POST alert payloads to (JSON body).  Leave empty to disable.
ALERT_WEBHOOK_URL=
