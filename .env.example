# ─────────────────────────────────────────────────────────────────────────────
# TheBox — Environment Configuration
# Copy this file to .env and adjust the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# Timezone
TZ=America/New_York

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=thebox
POSTGRES_USER=thebox
POSTGRES_PASSWORD=change_me_in_production

# ─── Pi-hole ─────────────────────────────────────────────────────────────────
PIHOLE_PASSWORD=change_me_in_production
PIHOLE_DNS_PORT=53
PIHOLE_WEB_PORT=8080

# ─── Dashboard ───────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
SECRET_KEY=change_me_in_production_to_a_random_string

# ─── Network Discovery ───────────────────────────────────────────────────────
# Comma-separated list of CIDR ranges to scan
NETWORK_RANGES=192.168.1.0/24
# Scan interval in seconds (default: 5 minutes)
SCAN_INTERVAL=300
# Enable DNS packet sniffing to discover devices from their DNS queries
# (requires NET_RAW capability; most effective with network_mode: host on Linux)
DNS_SNIFF_ENABLED=true
# Network interface to sniff on (leave empty for auto-detection)
DNS_SNIFF_IFACE=

# ─── Device Guardian ─────────────────────────────────────────────────────────
# CIDR range used for quarantined devices
QUARANTINE_VLAN=192.168.99.0/24
# Comma-separated list of trusted network ranges
TRUSTED_NETWORKS=192.168.1.0/24
# Automatically quarantine new/unknown devices
AUTO_QUARANTINE=true

# ─── IoT Learning ────────────────────────────────────────────────────────────
# Hours a new IoT device spends in the observation (learning) group before
# its DNS queries are collected and it is moved to the permanent iot group.
IOT_LEARNING_HOURS=48
# Name of the Pi-hole group that IoT devices are placed in after learning.
# This group should be configured in Pi-hole with the IoT allow-list blocklist.
PIHOLE_IOT_GROUP=iot

# ─── Honeypot ────────────────────────────────────────────────────────────────
# Comma-separated list of ports the honeypot listens on.
# On macOS, port 22 is automatically excluded by setup.sh because macOS's
# built-in OpenSSH service already binds that port.
HONEYPOT_PORTS=21,22,23,25,80,110,143,443,445,3306,3389,8080
# Comma-separated list of IP addresses or CIDR ranges to silently ignore.
# Connections from these addresses are dropped without logging or alerting.
# The default covers Docker bridge gateway addresses (172.16.0.0/12) and
# loopback (127.0.0.0/8) to prevent internal Docker health-checks from
# flooding the event log.
HONEYPOT_IGNORED_NETWORKS=172.16.0.0/12,127.0.0.0/8

# ─── Redirector ──────────────────────────────────────────────────────────────
# Comma-separated list of active redirect modes.
# From least to most intrusive:
#   passive         — monitor only, no active redirection (default)
#   redirect_dns    — iptables DNAT to forward all DNS traffic to Pi-hole
#   arp_spoof       — ARP-spoof LAN hosts to intercept DNS/DHCP traffic
#   dhcp_advertise  — respond to DHCP requests with Pi-hole as DNS server
#   dhcp_starvation — exhaust upstream DHCP pool (WARNING: disruptive)
#   gateway_takeover — full MitM via ARP spoofing all hosts + the gateway
REDIRECT_MODE=passive
# Network interface used for ARP/packet operations (auto-detected on Linux)
NETWORK_INTERFACE=eth0
# Default gateway IP (auto-detected from routing table if left empty)
GATEWAY_IP=
# Pi-hole IP address (defaults to BOX_IP / TheBox's own address if empty)
PIHOLE_IP=
# TheBox's own IP address (auto-detected from NETWORK_INTERFACE if empty)
BOX_IP=
# Drop all traffic from quarantined devices except DHCP and DNS
BLACKHOLE_QUARANTINED=false
# Seconds between ARP refresh packets for active spoof modes
ARP_REFRESH_INTERVAL=10

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
